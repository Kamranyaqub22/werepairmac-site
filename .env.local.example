# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# SMTP settings (Gmail example — use an App Password, not your real password)
# To create a Gmail App Password: myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kamran.yaqub2@gmail.com
SMTP_PASSWORD=your-16-char-gmail-app-password

# The email address that receives contact form submissions
CONTACT_EMAIL=info@werepairmac.co.uk

# Google Analytics 4
# 1. Go to analytics.google.com → Admin → Create Property → Web → copy the Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-53GRHDW428

# Microsoft Clarity (free heatmaps & session replay — consent-gated)
# 1. Sign up free at clarity.microsoft.com → create a project for werepairmac.co.uk
# 2. Settings → Setup → copy the Project ID (the short code in the tracking snippet)
NEXT_PUBLIC_CLARITY_ID=your-clarity-project-id

# Bing Webmaster Tools verification (optional — you can also just import from
# Google Search Console, which needs no code at all)
# 1. Sign in at bing.com/webmasters → Add site → choose the meta-tag method
# 2. Copy the value from content="..." in the <meta name="msvalidate.01"> tag
BING_SITE_VERIFICATION=your-bing-verification-code

# Google Reviews (auto-fetched every hour)
# 1. Go to console.cloud.google.com → enable "Places API" → create an API key
# 2. Find your Place ID at: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
#    Search for "We Repair Mac" and copy the Place ID (starts with ChIJ...)
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_PLACE_ID=ChIJ_your_place_id_here
